<h2 class="section-title">🏗️ Prebuilt Neural Rigs</h2>
<p style="color:var(--text-dim);margin-bottom:1.5rem;text-align:center;">Complete brain configurations — ready to install. Hit "Sync to Brain" to claim.</p>

<div class="prebuilts-grid">
  <% prebuilts.forEach((pb, i) => { %>
    <div class="prebuilt-card glass-card">
      <div class="pb-header">
        <h3><%= pb.name %></h3>
        <% if (pb.discount > 0) { %>
          <span class="pb-sale">🔥 <%= pb.discount %>% OFF</span>
        <% } %>
      </div>
      <p class="pb-desc"><%= pb.desc %></p>
      <div class="pb-parts">
        <% pb.parts.forEach(p => { %>
          <span class="pb-part-tag"><%= p %></span>
        <% }) %>
      </div>
      <div class="pb-pricing">
        <% if (pb.discount > 0) { %>
          <span class="pb-old-price">$ <%= (pb.price / (1 - pb.discount/100)).toFixed(2) %></span>
          <span class="pb-new-price">$ <%= pb.price.toFixed(2) %></span>
        <% } else { %>
          <span class="pb-new-price">$ <%= pb.price.toFixed(2) %></span>
        <% } %>
      </div>
      <button class="btn btn-primary btn-sm pb-buy-btn" data-name="<%= pb.name %>" data-price="<%= pb.price %>">⚡ Sync to Brain</button>
      <div class="sync-progress hidden" style="margin-top:0.8rem;">
        <div class="progress-bar"><div class="progress-fill"></div></div>
        <div class="sync-status" style="font-family:var(--mono);font-size:0.75rem;">Initiating...</div>
      </div>
    </div>
  <% }) %>
</div>
