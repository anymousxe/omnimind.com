<h2 class="section-title">💰 Sell Your Neural Parts</h2>
<p style="color:var(--text-dim);margin-bottom:1.5rem;text-align:center;">List your custom parts on the Cortex-Commerce marketplace.</p>

<div class="sell-form glass-card" style="max-width:600px;margin:0 auto;padding:2rem;">
  <div class="form-group">
    <label>Part Name</label>
    <input type="text" id="sell-name" placeholder="e.g. HyperSynapse Turbo X" class="sell-input">
  </div>
  <div class="form-group">
    <label>Category</label>
    <select id="sell-category" class="sell-input">
      <option value="Synaptic Accelerators">⚡ Synaptic Accelerators</option>
      <option value="Bio-Cooling">❄️ Bio-Cooling</option>
      <option value="Cortical GPUs">🖥️ Cortical GPUs</option>
      <option value="Frontal Lobe CPUs">🧮 Frontal Lobe CPUs</option>
      <option value="Memory Caches">💾 Memory Caches</option>
      <option value="Neuro-Link PSU">🔌 Neuro-Link PSU</option>
      <option value="Internet Chips">🌐 Internet Chips</option>
    </select>
  </div>
  <div class="form-group">
    <label>Price (₿)</label>
    <input type="number" id="sell-price" placeholder="499.99" step="0.01" min="0" class="sell-input">
  </div>
  <div class="form-group">
    <label>Specs (one per line, key: value)</label>
    <textarea id="sell-specs" placeholder="Clock Speed: 4800 MHz&#10;Cores: 32&#10;Cache: 64 MB" class="sell-input" rows="5"></textarea>
  </div>
  <button id="sell-submit" class="btn btn-primary">🛒 List on Marketplace</button>
  <div id="sell-result" class="sell-result hidden"></div>
</div>
