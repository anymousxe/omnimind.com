<div id="chat-bubble" class="chat-bubble" title="Cortex-Assistant">&#x1F9E0;</div>
<div id="chat-panel" class="chat-panel hidden">
  <div class="chat-header">
    <span>&#x1F9E0; Cortex-Assistant</span>
    <button id="chat-close">&times;</button>
  </div>
  <div id="chat-messages" class="chat-messages">
    <div class="chat-msg system">Welcome to Cortex-Commerce. I'm your neural technician. How can I help?</div>
  </div>
  <div class="chat-input-area">
    <input id="chat-input" type="text" placeholder="Ask about BrainOS parts..." autocomplete="off">
    <button id="chat-send">&#x2192;</button>
    <button id="chat-stop" class="chat-stop-btn hidden">&#x25A0;</button>
  </div>
</div>
